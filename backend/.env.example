# Database Configuration
DATABASE_URL=postgresql+asyncpg://attendance_user:your_secure_password@localhost:5432/attendance_db

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Biometric Settings
FACE_SIMILARITY_THRESHOLD=0.60
FINGERPRINT_MATCH_THRESHOLD=70
LIVENESS_THRESHOLD=0.70

# Attendance Settings
COOLDOWN_MINUTES=5
WORKDAY_START_HOUR=6
WORKDAY_END_HOUR=22

# CORS
CORS_ORIGINS=["http://localhost:3000","http://192.168.1.100:3000"]

# Rate Limiting
RATE_LIMIT_PER_DEVICE=30
RATE_LIMIT_PER_IP=100

# Debug Mode
DEBUG=false
