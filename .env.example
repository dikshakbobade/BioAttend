# BioAttend Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Database
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=bioattend_db
MYSQL_USER=bioattend_user
MYSQL_PASSWORD=your_password_here
MYSQL_ROOT_PASSWORD=your_root_password_here

# Database URL (auto-constructed from above)
DATABASE_URL=mysql+aiomysql://bioattend_user:your_password_here@db:3306/bioattend_db

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ENCRYPTION_KEY=your-fernet-encryption-key-here

# App
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# Face Recognition
FACE_SIMILARITY_THRESHOLD=0.6
LIVENESS_ENABLED=true
