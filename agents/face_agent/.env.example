# Face Recognition Agent Configuration

# Backend Server URL
BACKEND_URL=http://localhost:8000

# Device Identification (must be registered in backend)
DEVICE_ID=FACE-ENTRY-001

# API Key (obtained after device registration in admin dashboard)
API_KEY=your-device-api-key-from-admin-dashboard

# Camera Configuration
CAMERA_INDEX=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# Detection Settings
MIN_FACE_SIZE=100
DETECTION_CONFIDENCE=0.5

# Liveness Detection Thresholds
LIVENESS_BLINK_WEIGHT=0.30
LIVENESS_TEXTURE_WEIGHT=0.25
LIVENESS_MOTION_WEIGHT=0.25
LIVENESS_SKIN_WEIGHT=0.20

# Display Settings
SHOW_PREVIEW=true
PREVIEW_WINDOW_NAME=Face Recognition

# Cooldown after successful verification (seconds)
VERIFICATION_COOLDOWN=10

# Logging
LOG_LEVEL=INFO
