# Fingerprint Scanner Agent Configuration

# Backend Server URL
BACKEND_URL=http://localhost:8000

# Device Identification (must be registered in backend)
DEVICE_ID=FP-EXIT-001

# API Key (obtained after device registration in admin dashboard)
API_KEY=your-device-api-key-from-admin-dashboard

# Scanner Configuration
# Supported vendors: mantra, secugen, zkteco
SCANNER_VENDOR=mantra

# Mantra MFS100 specific settings
MANTRA_TIMEOUT=10000
MANTRA_QUALITY_THRESHOLD=60

# SecuGen specific settings
SECUGEN_BRIGHTNESS=50
SECUGEN_CONTRAST=50

# ZKTeco specific settings
ZKTECO_DPI=500

# Quality Settings
MIN_QUALITY_SCORE=60
MAX_CAPTURE_ATTEMPTS=3

# Cooldown after successful verification (seconds)
VERIFICATION_COOLDOWN=10

# Display Settings
SHOW_UI=true
UI_TITLE=Fingerprint Scanner

# Logging
LOG_LEVEL=INFO
